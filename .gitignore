# Python / FastAPI backend
__pycache__/
*.pyc
.venv/
venv/
env/
*.egg-info/
.pytest_cache/
.mypy_cache/
.ruff_cache/

# Almacenamiento temporal de archivos subidos (CSV/Excel) — el dato ya
# procesado vive en Postgres, el archivo crudo no se versiona.
backend/storage/

# Punto de entrega local de archivos crudos (CSV/Excel) pendientes de cargar
# vía la API — nunca se versionan datos de negocio reales.
data/raw/*
!data/raw/.gitkeep
!data/raw/README.md

# Node / React frontend
node_modules/
dist/
build/
.vite/
*.tsbuildinfo

# Env & secrets
.env
.env.*
!.env.example

# Docker
*.log

# OS / editor
.DS_Store
Thumbs.db
.vscode/
.idea/

# Claude Code local session artifacts
.claude/settings.local.json
