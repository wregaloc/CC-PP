# Entorno
# En producción (Cloud Run): ENVIRONMENT=production, DEBUG=false.
# Con ENVIRONMENT=production, app/core/config.py exige además COOKIE_SECURE=true,
# DATABASE_SSL_REQUIRED=true, CORS_ORIGINS sin vacío/"*" y un JWT_SECRET_KEY de
# 32+ caracteres — el proceso no arranca si alguna de esas condiciones falla
# (fail closed, ver [[enterprise-security]]).
# PORT: no se declara acá — Cloud Run la inyecta automáticamente y el
# Dockerfile ya la usa (uvicorn --port ${PORT:-8080}); no hace falta setearla.
ENVIRONMENT=development
DEBUG=true

# Base de datos (Supabase Postgres — nunca hardcodear credenciales en el código).
# Usa el proyecto de Supabase de DESARROLLO (no el marcado como producción).
# Panel del proyecto > botón "Connect" > pestaña "Direct" (o el modo "session pooler"
# puerto 5432 si tu proyecto solo muestra variantes de pooler). Antepón "+asyncpg"
# al esquema. Ver database/README.md.
DATABASE_URL=postgresql+asyncpg://postgres.<tu-project-ref>:<tu_password>@aws-1-<region>.pooler.supabase.com:5432/postgres
DATABASE_SSL_REQUIRED=true

# JWT (ver [[enterprise-security]] — nunca compartir el secreto real, generar uno propio por entorno)
JWT_SECRET_KEY=<genera_un_secreto_largo_y_aleatorio>
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=15
JWT_REFRESH_TOKEN_EXPIRE_DAYS=30

# Cookie del refresh token (ver [[enterprise-security]]): Secure exige HTTPS.
# En local (http://127.0.0.1, sin NGINX/TLS) el navegador descarta la cookie si
# esto es true, así que se apaga solo en desarrollo. En producción debe ser true.
COOKIE_SECURE=false

# Rate limiting de login — TDD §9.3: 5 intentos / 15 min por IP (implementado
# contra Postgres, no Redis; ver docs/PODPULSE_TDD_v1.0.docx y app/models/revoked_token.py)
LOGIN_MAX_ATTEMPTS=5
LOGIN_LOCKOUT_MINUTES=15

# Almacenamiento temporal de archivos subidos (Admin) — ruta relativa a backend/.
# Se borra cada archivo tras procesarse; no requiere backup propio (ver docs/API.md).
UPLOAD_STORAGE_DIR=storage/uploads

# Asistente de IA (solo Admin) — consulta datos reales del dashboard vía
# tool-use, nunca SQL directo. Key gratuita en https://aistudio.google.com/apikey
# (tier gratis de Gemini). Vacío = el endpoint responde 503, no rompe el arranque.
GEMINI_API_KEY=
GEMINI_MODEL=gemini-flash-latest

# CORS (orígenes permitidos, separados por coma). En producción: el dominio
# real del frontend en Vercel (https://tu-app.vercel.app o el dominio custom),
# nunca "*" — CORSMiddleware usa allow_credentials=True, y la spec CORS ya
# rechaza combinar credentials con origen comodín.
CORS_ORIGINS=http://localhost:5173

# Logging — en producción usar INFO (DEBUG es muy verboso para un agregador
# de logs real y puede incluir detalle innecesario).
LOG_LEVEL=DEBUG
