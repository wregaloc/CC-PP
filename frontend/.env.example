# URL base de la API del backend (Vite solo expone al cliente variables con prefijo VITE_)
# En producción (Vercel): la URL pública del servicio de Cloud Run, incluyendo
# el prefijo /api/v1 (p. ej. https://podpulse-backend-xxxxx.a.run.app/api/v1).
# Se configura en el dashboard de Vercel (Project Settings > Environment
# Variables) — nunca se versiona un valor real acá, este archivo es solo la
# plantilla (ver [[local-development-environment]]).
VITE_API_BASE_URL=http://localhost:8000/api/v1
